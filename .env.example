# ======================================
# VERCEL ENVIRONMENT VARIABLES
# ======================================
# Copy this file to .env.local for local development
# Add these to Vercel Dashboard > Project Settings > Environment Variables
# ======================================

# === BROWSER-SAFE (exposed to client via Vite) ===
# These are safe to expose - they're public keys with RLS protection
VITE_SUPABASE_URL_A=https://your-project-a.supabase.co
VITE_SUPABASE_ANON_KEY_A=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-a

# OPTIONAL: Project B (Vault) - Omit if using single-project mode
# VITE_SUPABASE_URL_B=https://your-project-b.supabase.co
# VITE_SUPABASE_ANON_KEY_B=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-b

# === SERVER-ONLY (Vercel Functions only) ===
# NEVER expose these to the browser!
SUPABASE_URL_A=https://your-project-a.supabase.co
SUPABASE_ANON_KEY_A=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-a
SUPABASE_SERVICE_ROLE_KEY_A=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-a

# OPTIONAL: Project B (Vault) - Omit if using single-project mode
# SUPABASE_URL_B=https://your-project-b.supabase.co
# SUPABASE_SERVICE_ROLE_KEY_B=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-b

# === IMPORTANT NOTES ===
# 1. Get keys from: Supabase Dashboard > Project Settings > API
# 2. VITE_ prefix = exposed to browser (client-side)
# 3. No prefix = server-only (Vercel Functions)
# 4. NEVER commit actual keys to git!
