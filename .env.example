# ======================================
# VERCEL ENVIRONMENT VARIABLES
# ======================================
# Copy this file to .env.local for local development
# Add these to Vercel Dashboard > Project Settings > Environment Variables
# ======================================

# === BROWSER-SAFE (exposed to client via Vite) ===
# These are safe to expose - they're public keys with RLS protection
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# === SERVER-ONLY (Vercel Functions only) ===
# NEVER expose these to the browser!
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here

# === OPTIONAL: API Security ===
# Use this to protect internal API calls between services
# API_SECRET_TOKEN=your-random-secret-token

# === IMPORTANT NOTES ===
# 1. Get keys from: Supabase Dashboard > Project Settings > API
# 2. VITE_ prefix = exposed to browser (client-side)
# 3. No prefix = server-only (Vercel Functions)
# 4. NEVER commit actual keys to git!
